# Copy this file to .env.local and fill in the value.
# .env.local is gitignored — never commit real values.
#
# Your deployed Google Apps Script Web App /exec URL.
# Get it from: script.google.com → Deploy → Manage deployments → Web app URL.
# Leave the placeholder and the frontend falls back to CONFIG.gifts for local
# gift-list preview without hitting the backend.
VITE_APPSCRIPT_URL=https://script.google.com/macros/s/REPLACE_ME/exec
